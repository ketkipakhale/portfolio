# ============================================
# KETAKI PAKHALE — PORTFOLIO .gitignore
# ============================================

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# Editor & IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# Logs
*.log
npm-debug.log*

# Dependencies (if added later)
node_modules/
package-lock.json

# Build output (if added later)
dist/
build/
.cache/

# Environment variables (NEVER push these)
.env
.env.local
.env.production

# Zip files
*.zip
*.rar
*.tar.gz

# Temp files
*.tmp
*.temp
*.swp
*~
